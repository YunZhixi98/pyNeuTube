include README.md
include LICENSE
include CITATION.cff
include pyproject.toml
include setup.py
include Cython_setup.py
include MANIFEST.in
include requirements.txt
include environment.yml

graft conda-recipe
graft docs
graft examples
graft pyneutube
graft tests
graft tools

recursive-include pyneutube *.pyx *.pxd *.c
recursive-include tests *.py

include examples/data/reference_volume.nii.gz
include examples/data/reference_neutube.swc

prune build
prune dist
prune .build_meta
prune .pip_tmp
prune .pip_target
prune .pytest_tmp
prune .wheelhouse
prune debug
prune examples/converted

exclude examples/reference_trace_smoke.png
exclude examples/reference_trace_smoke.swc
exclude tracers/pyNeuTube/filters_tmp_backup.pyx

global-exclude __pycache__/*
global-exclude *.py[cod]
global-exclude *.pyd
global-exclude *.so
global-exclude *.dll
global-exclude *.obj
global-exclude *.exp
global-exclude *.lib
